# Firmgate — copy to .env and adjust before docker compose up or bare-metal deploy.
# Generate a secret: openssl rand -hex 32

SECRET_KEY=replace-with-openssl-rand-hex-32
FLASK_DEBUG=0

# --- Docker Compose defaults (paths inside the container) ---
DATABASE_URL=sqlite:////data/instance/secure_browser.db
UPLOAD_ROOT=/data/instance/uploads

# --- Bare-metal example (uncomment and use on a Linux server) ---
# DATABASE_URL=sqlite:////var/lib/firmgate/secure_browser.db
# UPLOAD_ROOT=/var/lib/firmgate/uploads

# Branding
PORTAL_PRODUCT_NAME=Firmgate
MFA_ISSUER=Firmgate

# Upload limit (MB)
MAX_UPLOAD_MB=4096

# Docker host port mapping (docker compose only)
FIRMGATE_HTTP_PORT=5001

# Gunicorn (Docker entrypoint)
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=300

# Community Edition (1): fixed module allowlist; premium add-ons need a license key.
COMMUNITY_EDITION=1
# Enterprise license verification (FG2 Ed25519). Usually use app/enterprise_license_public.b64.
# Override only if you ship a custom public key per deployment:
# FIRMGATE_LICENSE_PUBLIC_KEY=

# AI Document Search (OpenAI-compatible API)
# AI_LLM_API_KEY=
# OPENAI_API_KEY=
# AI_LLM_BASE_URL=https://api.openai.com/v1
# AI_LLM_MODEL=gpt-4o-mini
# AI_LLM_SKIP_TLS_VERIFY=0
# AI_DOC_INDEX_BATCH=120
# AI_LLM_EMBEDDING_MODEL=text-embedding-3-small
# AI_DOC_CHUNK_CHARS=2000
# AI_DOC_MAX_CHUNKS=150
# AI_DOC_MAX_FILE_CHARS=600000
# AI_DOC_EMBED_BATCH=48
# AI_DOC_SEARCH_TOP_K=18
# AI Chatbot (optional separate key; falls back to AI_LLM_* when unset)
# AI_CHATBOT_API_KEY=
# AI_CHATBOT_BASE_URL=https://api.openai.com/v1
# AI_CHATBOT_MODEL=gpt-4o-mini
# Indexing scope and chatbot system prompt are configured in Administration → AI Settings.

# --- Optional integrations ---
# ONLYOFFICE_APP_URL=https://portal.example.com
# ONLYOFFICE_DOCUMENT_SERVER_URL=https://onlyoffice.example.com
# WEBRTC_STUN_URL=stun:stun.l.google.com:19302
# VOICE_CALL_MODE=webrtc

# --- Optional in-app upgrades (bare metal) ---
# ENABLE_SOFTWARE_GIT_UPGRADE=1
# ENABLE_SOFTWARE_PACKAGE_UPGRADE=1
# SOFTWARE_UPGRADE_SERVICE_NAME=intranet
