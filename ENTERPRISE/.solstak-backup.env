# SolStak Gitea full backup credentials (private — never commit the real file).
#
# Setup:
#   cp .solstak-backup.env.example .solstak-backup.env
#   # Edit .solstak-backup.env and set SOLSTAK_GIT_PASSWORD
#
# Used by scripts/solstak-backup-push.sh, scripts/release-and-backup.sh, and upload.sh
# when pushing to your Gitea remote (https://git.solstak.com.au/).

SOLSTAK_GIT_USER=snoothdogg
SOLSTAK_GIT_PASSWORD=sdfgsdfasdfadfgadgqdfadASDF22v

# Full backup repository (everything: source, PRIVATE/, release ZIPs, licensing tooling).
SOLSTAK_GIT_URL=https://git.solstak.com.au/snoothdogg/intranet.git
SOLSTAK_GIT_REMOTE=origin
SOLSTAK_GIT_BRANCH=main

# Set to 0 to skip automatic backup after scripts/build_edition_packages.sh
# SOLSTAK_BACKUP_AFTER_BUILD=1
