# Firmgate — copy to .env and adjust before docker compose up or bare-metal deploy.
# Generate a secret: openssl rand -hex 32

SECRET_KEY=replace-with-openssl-rand-hex-32
FLASK_DEBUG=0

# --- Docker Compose defaults (paths inside the container) ---
DATABASE_URL=sqlite:////data/instance/secure_browser.db
UPLOAD_ROOT=/data/instance/uploads

# --- Bare-metal example (uncomment and use on a Linux server) ---
# DATABASE_URL=sqlite:////var/lib/firmgate/secure_browser.db
# UPLOAD_ROOT=/var/lib/firmgate/uploads

# Branding
PORTAL_PRODUCT_NAME=Firmgate
MFA_ISSUER=Firmgate

# Upload limit (MB)
MAX_UPLOAD_MB=4096

# Docker host port mapping (docker compose only)
FIRMGATE_HTTP_PORT=5001

# Gunicorn (Docker entrypoint)
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=300

# Module allowlist (1 = enforce built-in module list).
COMMUNITY_EDITION=1

# --- Optional integrations ---
# ONLYOFFICE_APP_URL=https://portal.example.com
# Local OnlyOffice in Docker + Firmgate on host (macOS/Windows Docker Desktop):
# ONLYOFFICE_APP_URL=http://host.docker.internal:5001
# ONLYOFFICE_DOCUMENT_SERVER_URL=http://localhost:8080
# WEBRTC_STUN_URL=stun:stun.l.google.com:19302
# VOICE_CALL_MODE=webrtc

# --- Optional in-app upgrades (bare metal) ---
# ENABLE_SOFTWARE_GIT_UPGRADE=1
# SOFTWARE_UPGRADE_SERVICE_NAME=intranet
